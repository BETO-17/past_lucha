---
// InstagramFeed.astro
const posts = [
  "/src/assets/Cheesecake-de-Maracuyá.png",
  "/src/assets/Macarons.png",
  "/src/assets/Tarta-de-Frutas.png",
  "/src/assets/Torta-Selva-Negra.png",
];
---
<section class="instagram">
  <h2>Síguenos en @dulcearte</h2>
  <div class="insta-grid">
    {posts.map((img) => (
      <a href="https://instagram.com/postreslucha?igsh=c283emJuNmFoZmw0" target="_blank">
        <img src={img} alt="Publicación Instagram" />
      </a>
    ))}
  </div>
</section>

<style>
  .instagram {
    padding: 3rem 2rem;
    text-align: center;
  }
  .insta-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.5rem;
    max-width: 800px;
    margin: 1rem auto;
  }
  .insta-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 0.5rem;
    transition: opacity 0.3s;
  }
  .insta-grid img:hover {
    opacity: 0.8;
  }
</style>
