---
---

<div id="calendarComponent" style="background: white; border-radius: var(--radius); padding: 25px; box-shadow: var(--shadow);">
  <h3 style="font-size: 1.1rem; font-weight: 600; margin-bottom: 20px;">Selecciona una Fecha</h3>
  
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <button id="prevMonth" style="background: none; font-size: 1.2rem; color: var(--primary); padding: 5px 10px;">‹</button>
    <span id="monthYear" style="font-weight: 600; font-size: 1rem;"></span>
    <button id="nextMonth" style="background: none; font-size: 1.2rem; color: var(--primary); padding: 5px 10px;">›</button>
  </div>
  
  <div style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px; text-align: center; margin-bottom: 10px;">
    {['Lu', 'Mo', 'Mi', 'Ju', 'Vi', 'Va', 'Sa'].map(day => (
      <span style="font-size: 0.75rem; font-weight: 600; color: var(--text-light); padding: 5px;">{day}</span>
    ))}
  </div>
  
  <div id="calendarDays" style="display: grid; grid-template-columns: repeat(7, 1fr); gap: 5px;"></div>
  
  <div style="margin-top: 25px;">
    <h4 style="font-size: 0.95rem; font-weight: 600; margin-bottom: 12px;">Tiempos disponibles:</h4>
    <div id="timeSlots" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;"></div>
  </div>
</div>

<script>
  let currentDate = new Date();
  let selectedDate = null;
  let selectedTime = null;
  
  const monthNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
  
  function renderCalendar() {
    const year = currentDate.getFullYear();
    const month = currentDate.getMonth();
    
    document.getElementById('monthYear').textContent = `${monthNames[month]} ${year}`;
    
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const prevDaysInMonth = new Date(year, month, 0).getDate();
    
    const calendarDays = document.getElementById('calendarDays');
    calendarDays.innerHTML = '';
    
    // Previous month days
    const startOffset = firstDay === 0 ? 6 : firstDay - 1;
    for (let i = startOffset - 1; i >= 0; i--) {
      const day = document.createElement('div');
      day.textContent = prevDaysInMonth - i;
      day.style.cssText = 'padding: 8px; font-size: 0.85rem; color: #ccc; border-radius: 8px;';
      calendarDays.appendChild(day);
    }
    
    // Current month days
    const today = new Date();
    for (let i = 1; i <= daysInMonth; i++) {
      const day = document.createElement('button');
      day.textContent = i;
      day.style.cssText = `
        padding: 8px;
        font-size: 0.85rem;
        border-radius: 8px;
        background: none;
        border: none;
        cursor: pointer;
        transition: all 0.2s ease;
      `;
      
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      const isToday = today.getDate() === i && today.getMonth() === month && today.getFullYear() === year;
      const isPast = new Date(year, month, i) < new Date(today.getFullYear(), today.getMonth(), today.getDate());
      const isSelected = selectedDate === dateStr;
      
      // Check if date is booked
      const bookings = JSON.parse(localStorage.getItem('bookings') || '[]');
      const isBooked = bookings.some(b => b.date === dateStr);
      
      if (isPast) {
        day.style.color = '#ddd';
        day.style.cursor = 'not-allowed';
        day.disabled = true;
      } else if (isSelected) {
        day.style.background = 'var(--primary)';
        day.style.color = 'white';
      } else if (isBooked) {
        day.style.background = '#ffebee';
        day.style.color = '#c62828';
      } else if (isToday) {
        day.style.background = 'var(--primary-light)';
        day.style.color = 'var(--primary)';
        day.style.fontWeight = '600';
      } else {
        day.style.color = 'var(--text)';
        day.onmouseover = () => { if (!isBooked) { day.style.background = 'var(--primary-light)'; } };
        day.onmouseout = () => { if (!isSelected) { day.style.background = 'transparent'; } };
      }
      
      if (!isPast && !isBooked) {
        day.addEventListener('click', () => {
          selectedDate = dateStr;
          selectedTime = null;
          renderCalendar();
          renderTimeSlots();
          
          // Store in localStorage for form
          localStorage.setItem('selectedDate', dateStr);
        });
      }
      
      calendarDays.appendChild(day);
    }
    
    // Next month days
    const remaining = (7 - ((startOffset + daysInMonth) % 7)) % 7;
    for (let i = 1; i <= remaining; i++) {
      const day = document.createElement('div');
      day.textContent = i;
      day.style.cssText = 'padding: 8px; font-size: 0.85rem; color: #ccc; border-radius: 8px;';
      calendarDays.appendChild(day);
    }
  }
  
  function renderTimeSlots() {
    const times = ['10:00 AM', '11:30 AM', '2:00 PM', '3:30 PM'];
    const container = document.getElementById('timeSlots');
    container.innerHTML = '';
    
    if (!selectedDate) {
      container.innerHTML = '<p style="grid-column: span 2; color: var(--text-light); font-size: 0.85rem;">Selecciona una fecha primero</p>';
      return;
    }
    
    const bookings = JSON.parse(localStorage.getItem('bookings') || '[]');
    const bookedTimes = bookings.filter(b => b.date === selectedDate).map(b => b.time);
    
    times.forEach(time => {
      const btn = document.createElement('button');
      btn.textContent = time;
      const isBooked = bookedTimes.includes(time);
      const isSelected = selectedTime === time;
      
      btn.style.cssText = `
        padding: 10px;
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        font-weight: 500;
        border: 1.5px solid ${isSelected ? 'var(--primary)' : isBooked ? '#ffcdd2' : '#e0e0e0'};
        background: ${isSelected ? 'var(--primary)' : isBooked ? '#ffebee' : 'white'};
        color: ${isSelected ? 'white' : isBooked ? '#c62828' : 'var(--text)'};
        cursor: ${isBooked ? 'not-allowed' : 'pointer'};
        transition: all 0.2s ease;
      `;
      
      if (!isBooked) {
        btn.onmouseover = () => { if (!isSelected) { btn.style.borderColor = 'var(--primary)'; btn.style.color = 'var(--primary)'; } };
        btn.onmouseout = () => { if (!isSelected) { btn.style.borderColor = '#e0e0e0'; btn.style.color = 'var(--text)'; } };
        btn.addEventListener('click', () => {
          selectedTime = time;
          localStorage.setItem('selectedTime', time);
          renderTimeSlots();
        });
      }
      
      container.appendChild(btn);
    });
  }
  
  document.getElementById('prevMonth')?.addEventListener('click', () => {
    currentDate.setMonth(currentDate.getMonth() - 1);
    renderCalendar();
  });
  
  document.getElementById('nextMonth')?.addEventListener('click', () => {
    currentDate.setMonth(currentDate.getMonth() + 1);
    renderCalendar();
  });
  
  renderCalendar();
  renderTimeSlots();
</script>