---
// Appointment.astro
---
<section class="appointment" id="appointment">
  <div class="appointment-layout">
    <div class="image-container">
      <img src="/src/assets/espacio.png" alt="Degustación Doña Lucha" class="main-image" />
    </div>

    <div class="content-wrapper">
      <div class="text-header">
        <h2>Reserva tu cita de degustación</h2>
        <p>Prueba nuestros sabores antes de decidir. <br>
        Coordinamos contigo una visita a nuestro taller</p>
      </div>

      <form action="https://formspree.io/f/tu-id" method="POST" class="appointment-form">
        <input type="text" name="nombre" placeholder="Tu nombre" required />
        <input type="email" name="email" placeholder="Tu correo" required />
        <input type="tel" name="telefono" placeholder="Teléfono" />
        <textarea name="mensaje" placeholder="¿Qué tipo de evento o producto te interesa?"></textarea>
        <button type="submit" class="btn-submit">Solicitar cita</button>
      </form>

      <div class="calendly-box">
        <p>O agenda directamente en nuestro calendario:</p>
        <a href="https://calendly.com/tu-pasteleria" target="_blank" class="btn-availability">Ver disponibilidad</a>
      </div>
    </div>
  </div>
</section>

<style>
  .appointment {
    background-color: #fff; /* Fondo blanco general */
    padding: 4rem 2rem;
    display: flex;
    justify-content: center;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  }

  .appointment-layout {
    display: flex;
    max-width: 1200px;
    width: 100%;
    gap: 3rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  /* Lado Izquierdo: Imagen con borde morado fino */
  .image-container {
    flex: 1 1 500px;
    border: 3px solid #d05ce3; /* Borde morado como en la imagen */
    padding: 0;
    line-height: 0;
  }

  .main-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Lado Derecho: Contenedor con borde rosa */
  .content-wrapper {
    flex: 1 1 350px;
    max-width: 400px;
    border: 10px solid #fce4ec; /* Borde rosa grueso exterior */
    padding: 1.5rem 1.2rem;
    background-color: #fff;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .text-header {
    text-align: center;
  }

  .text-header h2 {
    color: #e91e63; /* Rosa fuerte/fucsia */
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    font-weight: bold;
  }

  .text-header p {
    color: #333;
    font-size: 0.9rem;
    line-height: 1.3;
  }

  /* Formulario */
  .appointment-form {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .appointment-form input, 
  .appointment-form textarea {
    padding: 0.6rem;
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    background-color: #fdfdfd;
  }

  .btn-submit {
    background-color: #d81b60;
    color: white;
    border: none;
    padding: 0.7rem;
    border-radius: 0.5rem;
    font-weight: bold;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .btn-submit:hover {
    background-color: #ad1457;
  }

  /* Sección Calendly dentro de la tarjeta blanca */
  .calendly-box {
    margin-top: 0.5rem;
    padding: 1rem;
    border-radius: 1.5rem;
    text-align: center;
    border: 1px solid #f0f0f0;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }

  .calendly-box p {
    color: #666;
    font-size: 0.8rem;
    margin-bottom: 0.7rem;
  }

  .btn-availability {
    display: inline-block;
    background-color: #d81b60;
    color: white;
    padding: 0.7rem 2rem;
    border-radius: 2rem;
    text-decoration: none;
    font-weight: bold;
  }

  /* Ajustes para móviles */
  @media (max-width: 768px) {
    .appointment-layout {
      flex-direction: column;
    }
    .content-wrapper {
      max-width: 100%;
    }
  }
</style>