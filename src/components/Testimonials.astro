---
// src/components/Testimonials.astro

const testimonios = [
  {
    texto: "La torta de cumpleaños fue la estrella de la fiesta. ¡Sabor casero y decoración impecable!",
    autor: "María G.",
    estrellas: 5,
  },
  {
    texto: "Hicieron mi torta de bodas soñada. Atención personalizada y puntualidad 10/10.",
    autor: "Lucía P.",
    estrellas: 5,
  },
  {
    texto: "Los macarons son los mejores que he probado. Los pido siempre para mis eventos.",
    autor: "Carlos R.",
    estrellas: 5,
  },
];
---

<section class="testimonials-container">
  <div class="testimonials-border-box">
    <h2 class="section-title">Lo que dicen nuestros clientes</h2>
    <div class="testimonial-list-wrapper" id="testimonial-list">
      {testimonios.map((t) => (
        <div class="testimonial-card">
          <p class="text">“{t.texto}”</p>
          <div class="stars">{"★".repeat(t.estrellas)}</div>
          <span class="author">— {t.autor}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="leave-review-card">
    <h3>Cuéntanos tu experiencia</h3>
    <form id="review-form">
      <input type="text" name="name" placeholder="Tu nombre" required />
      
      <div class="star-rating">
        <input type="radio" id="star5" name="rating" value="5" required />
        <label for="star5">★</label>
        <input type="radio" id="star4" name="rating" value="4" />
        <label for="star4">★</label>
        <input type="radio" id="star3" name="rating" value="3" />
        <label for="star3">★</label>
        <input type="radio" id="star2" name="rating" value="2" />
        <label for="star2">★</label>
        <input type="radio" id="star1" name="rating" value="1" />
        <label for="star1">★</label>
      </div>

      <textarea name="comment" rows="3" placeholder="Escribe tu comentario..." required></textarea>
      <button type="submit">Enviar comentario</button>
    </form>
  </div>
</section>

<script>
  interface Testimonial {
    name: string;
    comment: string;
    rating: number;
  }

  function loadUserTestimonials(): Testimonial[] {
    const stored = localStorage.getItem('pasteleriaTestimonials');
    return stored ? JSON.parse(stored) : [];
  }

  function saveUserTestimonials(list: Testimonial[]): void {
    localStorage.setItem('pasteleriaTestimonials', JSON.stringify(list));
  }

  function createTestimonialCard({ name, comment, rating }: Testimonial): HTMLDivElement {
  const card = document.createElement('div');
  // Usamos ambas clases para asegurar que reciba los estilos base y los específicos
  card.className = 'testimonial-card user-testimonial'; 
  
  card.innerHTML = `
    <p class="text">“${comment}”</p>
    <div class="stars">${'★'.repeat(rating)}${'☆'.repeat(5 - rating)}</div>
    <span class="author">— ${name}</span>
  `;
  return card;
}

  function renderUserTestimonials(): void {
    const grid = document.getElementById('testimonial-list');
    const userTestimonials = loadUserTestimonials();
    if (grid) {
      userTestimonials.forEach((t: Testimonial) => {
        grid.prepend(createTestimonialCard(t));
      });
    }
  }

  renderUserTestimonials();

  const reviewForm = document.getElementById('review-form') as HTMLFormElement;
  if (reviewForm) {
    reviewForm.addEventListener('submit', function(e: Event) {
      e.preventDefault();
      const formData = new FormData(this as HTMLFormElement);
      const name = (formData.get('name') as string).trim();
      const comment = (formData.get('comment') as string).trim();
      const rating = formData.get('rating') as string;

      if (!rating) {
        alert('Por favor, selecciona una calificación.');
        return;
      }

      const newTestimonial: Testimonial = {
        name,
        comment,
        rating: parseInt(rating, 10)
      };

      const currentList = loadUserTestimonials();
      currentList.push(newTestimonial);
      saveUserTestimonials(currentList);

      const grid = document.getElementById('testimonial-list');
      if (grid) {
        grid.prepend(createTestimonialCard(newTestimonial));
      }

      this.reset();
      const starInputs = document.querySelectorAll('.star-rating input') as NodeListOf<HTMLInputElement>;
      starInputs.forEach(input => input.checked = false);
    });
  }
</script>

<style>
  /* Contenedor General */
  .testimonials-container {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 3rem;
    padding: 4rem 2rem;
    background-color: #fff;
    font-family: sans-serif;
  }

  /* Sección de Testimonios (Derecha en la imagen) */
  .testimonials-border-box {
    border: 15px solid #fce4ec; /* Marco rosa claro grueso */
    padding: 2rem;
    max-width: 500px;
    width: 100%;
  }

  .section-title {
    background-color: #ff80ab; /* Fondo fucsia redondeado */
    color: white;
    display: inline-block;
    padding: 0.5rem 2rem;
    border-radius: 2rem;
    font-size: 1.5rem;
    margin-bottom: 2rem;
  }

  .testimonial-list-wrapper {
    border: 2px solid #7e57c2; /* Borde morado de la lista */
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-height: 500px;
    overflow-y: auto;
  }

  .testimonial-card {
    background: #fff;
    border-radius: 0.8rem;
    padding: 1.5rem;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    text-align: left;
    width: 100%;
    box-sizing: border-box;
  }
  .user-testimonial {
  margin-bottom: 1rem;
  border-bottom: 1px solid #eee; /* Separador ligero entre comentarios */
}

  .text {
    font-style: italic;
    color: #444;
    margin-bottom: 0.5rem;
  }

  .stars {
    color: #ffca28;
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .author {
    font-weight: bold;
    color: #222;
  }

  /* Formulario (Izquierda en la imagen) */
  .leave-review-card {
    background-color: #fff5f7;
    padding: 2.5rem;
    border-radius: 1.5rem;
    width: 100%;
    max-width: 450px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }

  .leave-review-card h3 {
    color: #d81b60;
    margin-bottom: 1.5rem;
  }

  .leave-review-card input, 
  .leave-review-card textarea {
    width: 100%;
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    padding: 0.8rem;
    margin-bottom: 1rem;
    font-family: inherit;
  }

  .leave-review-card button {
    background-color: #d81b60;
    color: white;
    border: none;
    padding: 0.8rem 2rem;
    border-radius: 2rem;
    font-weight: bold;
    cursor: pointer;
    width: 60%;
  }

  /* Estrellas interactivas */
  .star-rating {
    display: flex;
    flex-direction: row-reverse;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .star-rating input { display: none; }
  .star-rating label {
    font-size: 2rem;
    color: #e0e0e0;
    cursor: pointer;
  }
  .star-rating input:checked ~ label,
  .star-rating label:hover,
  .star-rating label:hover ~ label {
    color: #ffca28;
  }
</style>