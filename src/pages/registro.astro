---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Registro" description="Crea tu cuenta en Doña Lucha - Postres Cucharables">
  <div style="min-height: 100vh; display: flex; background: linear-gradient(135deg, #fff5f7 0%, #fce4ec 100%);">

    <!-- Left Panel - Branding -->
    <div style="
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 60px 40px;
      background: linear-gradient(180deg, #fce4ec 0%, #f8e1e8 50%, #fff0f3 100%);
      position: relative;
      overflow: hidden;
    ">
      <!-- Decorative circles -->
      <div style="position: absolute; top: -50px; left: -50px; width: 200px; height: 200px; background: rgba(194, 24, 91, 0.05); border-radius: 50%;"></div>
      <div style="position: absolute; bottom: -80px; right: -80px; width: 300px; height: 300px; background: rgba(194, 24, 91, 0.03); border-radius: 50%;"></div>

      <!-- Navigation (mini) -->
      <nav style="position: absolute; top: 30px; display: flex; gap: 30px;">
        <a href="/productos" style="color: #666; font-size: 0.85rem; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='#666'">Productos</a>
        <a href="/reserva" style="color: #666; font-size: 0.85rem; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='#666'">Reserva cita</a>
        <a href="/testimonios" style="color: #666; font-size: 0.85rem; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='#666'">Testimonios</a>
        <a href="/contacto" style="color: #666; font-size: 0.85rem; font-weight: 500; transition: color 0.3s;" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='#666'">Contacto</a>
      </nav>

      <!-- Logo -->
      <div style="margin-bottom: 40px;">
        <div style="width: 140px; height: 140px; margin: 0 auto 20px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 30px rgba(194, 24, 91, 0.15);">
          <svg width="90" height="90" viewBox="0 0 100 100" fill="none">
            <ellipse cx="50" cy="65" rx="35" ry="20" fill="#8B4513"/>
            <ellipse cx="50" cy="60" rx="35" ry="20" fill="#D2691E"/>
            <path d="M50 40 L50 20" stroke="#666" stroke-width="3"/>
            <circle cx="50" cy="18" r="5" fill="#666"/>
            <path d="M30 50 Q50 30 70 50" stroke="white" stroke-width="2" fill="none"/>
            <path d="M35 55 Q50 40 65 55" stroke="white" stroke-width="2" fill="none"/>
          </svg>
        </div>
        <div style="text-align: center;">
          <div style="font-size: 1.4rem; font-weight: 700; color: var(--primary); letter-spacing: 2px;">DOÑA LUCHA</div>
          <div style="font-size: 0.7rem; color: var(--text-light); letter-spacing: 3px; margin-top: 4px;">POSTRES CUCHARABLES</div>
        </div>
      </div>

      <!-- Tagline -->
      <h2 style="font-size: 1.8rem; font-weight: 700; color: var(--primary); text-align: center; margin-bottom: 15px; text-transform: uppercase; letter-spacing: 2px;">
        Pastelería Dulce Arte
      </h2>
      <p style="color: var(--text-light); text-align: center; font-size: 0.95rem; margin-bottom: 40px; max-width: 300px; line-height: 1.6;">
        Únete a nuestra comunidad de amantes de los postres artesanales
      </p>

      <!-- CTA Button -->
      <a href="/productos" style="
        display: inline-block;
        background: var(--primary);
        color: white;
        padding: 12px 35px;
        border-radius: 25px;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 50px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(194, 24, 91, 0.3);
      " onmouseover="this.style.background='var(--primary-dark)'; this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 20px rgba(194, 24, 91, 0.4)';" onmouseout="this.style.background='var(--primary)'; this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 15px rgba(194, 24, 91, 0.3)';">
        Explorar Productos
      </a>

      <!-- Stats -->
      <div style="display: flex; gap: 40px; text-align: center;">
        <div>
          <div style="font-size: 1.8rem; font-weight: 700; color: var(--primary);">+20</div>
          <div style="font-size: 0.75rem; color: var(--text-light); margin-top: 4px;">Variedades</div>
        </div>
        <div>
          <div style="font-size: 1.8rem; font-weight: 700; color: var(--primary);">50</div>
          <div style="font-size: 0.75rem; color: var(--text-light); margin-top: 4px;">Clientes felices</div>
        </div>
        <div>
          <div style="font-size: 1.8rem; font-weight: 700; color: var(--primary);">30</div>
          <div style="font-size: 0.75rem; color: var(--text-light); margin-top: 4px;">Años de experiencia</div>
        </div>
      </div>

      <!-- Footer text -->
      <div style="margin-top: 40px; text-align: center;">
        <div style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 5px;">Doña Lucha</div>
        <div style="font-size: 0.85rem; color: var(--text-light);">Postres Cucharables hechos con amor.</div>
      </div>
    </div>

    <!-- Right Panel - Register Form -->
    <div style="
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px 80px;
      background: white;
      overflow-y: auto;
    ">
      <div style="width: 100%; max-width: 420px;">
        <h1 style="font-size: 2.2rem; font-weight: 700; color: var(--primary); margin-bottom: 10px;">Crear Cuenta</h1>
        <p style="color: var(--text-light); font-size: 0.95rem; margin-bottom: 35px;">Únete a nuestra dulce comunidad.</p>

        <form id="registerForm">
          <!-- Full Name -->
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; color: var(--text); margin-bottom: 8px;">Nombre Completo</label>
            <div style="position: relative;">
              <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 1rem;">👤</span>
              <input 
                type="text" 
                name="fullName"
                placeholder="Tu nombre completo"
                required
                style="
                  width: 100%;
                  padding: 14px 14px 14px 45px;
                  border: 1.5px solid #e8e8e8;
                  border-radius: 12px;
                  font-family: 'Poppins', sans-serif;
                  font-size: 0.95rem;
                  background: #fafafa;
                  transition: all 0.3s ease;
                  outline: none;
                "
                onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'; this.style.boxShadow='0 0 0 3px rgba(194, 24, 91, 0.1)';"
                onblur="this.style.borderColor='#e8e8e8'; this.style.background='#fafafa'; this.style.boxShadow='none';"
              />
            </div>
          </div>

          <!-- Email -->
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; color: var(--text); margin-bottom: 8px;">Correo electrónico</label>
            <div style="position: relative;">
              <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 1rem;">✉</span>
              <input 
                type="email" 
                name="email"
                placeholder="tu@email.com"
                required
                style="
                  width: 100%;
                  padding: 14px 14px 14px 45px;
                  border: 1.5px solid #e8e8e8;
                  border-radius: 12px;
                  font-family: 'Poppins', sans-serif;
                  font-size: 0.95rem;
                  background: #fafafa;
                  transition: all 0.3s ease;
                  outline: none;
                "
                onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'; this.style.boxShadow='0 0 0 3px rgba(194, 24, 91, 0.1)';"
                onblur="this.style.borderColor='#e8e8e8'; this.style.background='#fafafa'; this.style.boxShadow='none';"
              />
            </div>
          </div>


          <!-- Password -->
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; color: var(--text); margin-bottom: 8px;">Contraseña</label>
            <div style="position: relative;">
              <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 1rem;">🔒</span>
              <input 
                type="password" 
                name="password"
                id="regPassword"
                placeholder="Mínimo 6 caracteres"
                minlength="6"
                required
                style="
                  width: 100%;
                  padding: 14px 14px 14px 45px;
                  border: 1.5px solid #e8e8e8;
                  border-radius: 12px;
                  font-family: 'Poppins', sans-serif;
                  font-size: 0.95rem;
                  background: #fafafa;
                  transition: all 0.3s ease;
                  outline: none;
                "
                onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'; this.style.boxShadow='0 0 0 3px rgba(194, 24, 91, 0.1)';"
                onblur="this.style.borderColor='#e8e8e8'; this.style.background='#fafafa'; this.style.boxShadow='none';"
              />
            </div>
            <div id="passwordStrength" style="margin-top: 8px; height: 4px; border-radius: 2px; background: #e8e8e8; overflow: hidden;">
              <div id="strengthBar" style="height: 100%; width: 0%; background: #e0e0e0; transition: all 0.3s ease;"></div>
            </div>
            <p id="strengthText" style="font-size: 0.75rem; color: #aaa; margin-top: 4px;">La contraseña debe tener al menos 6 caracteres</p>
          </div>

          <!-- Confirm Password -->
          <div style="margin-bottom: 22px;">
            <label style="display: block; font-size: 0.85rem; font-weight: 500; color: var(--text); margin-bottom: 8px;">Confirmar Contraseña</label>
            <div style="position: relative;">
              <span style="position: absolute; left: 15px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 1rem;">🔐</span>
              <input 
                type="password" 
                name="confirmPassword"
                placeholder="Repite tu contraseña"
                required
                style="
                  width: 100%;
                  padding: 14px 14px 14px 45px;
                  border: 1.5px solid #e8e8e8;
                  border-radius: 12px;
                  font-family: 'Poppins', sans-serif;
                  font-size: 0.95rem;
                  background: #fafafa;
                  transition: all 0.3s ease;
                  outline: none;
                "
                onfocus="this.style.borderColor='var(--primary)'; this.style.background='white'; this.style.boxShadow='0 0 0 3px rgba(194, 24, 91, 0.1)';"
                onblur="this.style.borderColor='#e8e8e8'; this.style.background='#fafafa'; this.style.boxShadow='none';"
              />
            </div>
          </div>

          <!-- Terms -->
          <div style="margin-bottom: 25px;">
            <label style="display: flex; align-items: flex-start; gap: 10px; cursor: pointer; font-size: 0.85rem; color: var(--text-light); line-height: 1.5;">
              <input type="checkbox" name="terms" required style="width: 18px; height: 18px; accent-color: var(--primary); cursor: pointer; margin-top: 2px; flex-shrink: 0;" />
              <span>Acepto los <a href="#" style="color: var(--primary); font-weight: 500;">términos y condiciones</a> y la <a href="#" style="color: var(--primary); font-weight: 500;">política de privacidad</a></span>
            </label>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit"
            style="
              width: 100%;
              background: var(--primary);
              color: white;
              padding: 15px;
              border-radius: 12px;
              font-weight: 600;
              font-size: 1rem;
              border: none;
              cursor: pointer;
              transition: all 0.3s ease;
              margin-bottom: 25px;
            "
            onmouseover="this.style.background='var(--primary-dark)'; this.style.transform='translateY(-1px)'; this.style.boxShadow='0 4px 15px rgba(194, 24, 91, 0.3)';"
            onmouseout="this.style.background='var(--primary)'; this.style.transform='translateY(0)'; this.style.boxShadow='none';"
          >
            Crear Cuenta
          </button>

          <!-- Divider -->
          <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 25px;">
            <div style="flex: 1; height: 1px; background: #e8e8e8;"></div>
            <span style="font-size: 0.8rem; color: #aaa;">O regístrate con</span>
            <div style="flex: 1; height: 1px; background: #e8e8e8;"></div>
          </div>

          <!-- Social Register -->
          <div style="display: flex; gap: 15px; margin-bottom: 30px;">
            <button type="button" style="
              flex: 1;
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              padding: 12px;
              border: 1.5px solid #e8e8e8;
              border-radius: 12px;
              background: white;
              font-family: 'Poppins', sans-serif;
              font-size: 0.9rem;
              color: var(--text);
              cursor: pointer;
              transition: all 0.3s ease;
            " onmouseover="this.style.borderColor='var(--primary)'; this.style.background='var(--primary-light)';" onmouseout="this.style.borderColor='#e8e8e8'; this.style.background='white';">
              <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Google
            </button>
            <button type="button" style="
              flex: 1;
              display: flex;
              align-items: center;
              justify-content: center;
              gap: 8px;
              padding: 12px;
              border: 1.5px solid #e8e8e8;
              border-radius: 12px;
              background: white;
              font-family: 'Poppins', sans-serif;
              font-size: 0.9rem;
              color: var(--text);
              cursor: pointer;
              transition: all 0.3s ease;
            " onmouseover="this.style.borderColor='var(--primary)'; this.style.background='var(--primary-light)';" onmouseout="this.style.borderColor='#e8e8e8'; this.style.background='white';">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877f2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
              Facebook
            </button>
          </div>

          <!-- Login Link -->
          <p style="text-align: center; font-size: 0.9rem; color: var(--text-light);">
            ¿Ya tienes cuenta? <a href="/login" style="color: var(--primary); font-weight: 600; transition: color 0.3s;" onmouseover="this.style.color='var(--primary-dark)'" onmouseout="this.style.color='var(--primary)'">Inicia sesión</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  @media (max-width: 768px) {
    div[style*="min-height: 100vh"] {
      flex-direction: column;
    }

    div[style*="flex: 1"][style*="background: linear-gradient"] {
      flex: none;
      min-height: 50vh;
      padding: 40px 20px;
    }

    div[style*="flex: 1"][style*="background: white"] {
      flex: none;
      padding: 40px 20px;
    }

    /* Navigation mini */
    nav[style*="position: absolute"] {
      display: none;
    }

    /* Logo */
    div[style*="margin-bottom: 40px"] {
      margin-bottom: 20px;
    }

    div[style*="width: 140px"] {
      width: 100px !important;
      height: 100px !important;
    }

    svg[viewBox="0 0 100 100"] {
      width: 60px !important;
      height: 60px !important;
    }

    div[style*="font-size: 1.4rem"] {
      font-size: 1.1rem !important;
    }

    div[style*="font-size: 0.7rem"] {
      font-size: 0.6rem !important;
    }

    /* Tagline */
    h2[style*="font-size: 1.8rem"] {
      font-size: 1.4rem !important;
    }

    p[style*="font-size: 0.95rem"] {
      font-size: 0.85rem !important;
    }

    /* CTA Button */
    a[href="/productos"][style*="padding: 12px 35px"] {
      padding: 10px 25px !important;
      font-size: 0.8rem !important;
    }

    /* Stats */
    div[style*="display: flex; gap: 40px"] {
      gap: 20px !important;
    }

    div[style*="font-size: 1.8rem"] {
      font-size: 1.4rem !important;
    }

    div[style*="font-size: 0.75rem"] {
      font-size: 0.65rem !important;
    }

    /* Footer text */
    div[style*="margin-top: 40px"] {
      margin-top: 20px !important;
    }

    div[style*="font-size: 1.3rem"] {
      font-size: 1rem !important;
    }

    div[style*="font-size: 0.85rem"] {
      font-size: 0.75rem !important;
    }

    /* Form */
    h1[style*="font-size: 2.2rem"] {
      font-size: 1.8rem !important;
    }

    p[style*="font-size: 0.95rem"] {
      font-size: 0.85rem !important;
    }

    /* Social buttons */
    div[style*="display: flex; gap: 15px; margin-bottom: 30px;"] {
      flex-direction: column !important;
      gap: 10px !important;
    }

    button[type="button"][style*="flex: 1"] {
      width: 100% !important;
    }
  }

  @media (max-width: 480px) {
    div[style*="flex: 1"][style*="background: linear-gradient"] {
      padding: 30px 15px;
    }

    div[style*="flex: 1"][style*="background: white"] {
      padding: 30px 15px;
    }

    /* Logo */
    div[style*="width: 140px"] {
      width: 80px !important;
      height: 80px !important;
    }

    svg[viewBox="0 0 100 100"] {
      width: 50px !important;
      height: 50px !important;
    }

    div[style*="font-size: 1.4rem"] {
      font-size: 1rem !important;
    }

    /* Tagline */
    h2[style*="font-size: 1.8rem"] {
      font-size: 1.2rem !important;
    }

    /* Stats */
    div[style*="display: flex; gap: 40px"] {
      gap: 15px !important;
    }

    /* Form */
    h1[style*="font-size: 2.2rem"] {
      font-size: 1.5rem !important;
    }
  }
</style>

<script>
  import { getSession, registerUser } from '../scripts/storage.js';

  document.getElementById('registerForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    e.stopImmediatePropagation();

    const formData = new FormData(e.currentTarget);
    const fullName = String(formData.get('fullName') || '').trim();
    const email = String(formData.get('email') || '').trim();
    const password = String(formData.get('password') || '');
    const confirmPassword = String(formData.get('confirmPassword') || '');

    if (password !== confirmPassword) {
      alert('Las contraseñas no coinciden.');
      return;
    }

    if (password.length < 6) {
      alert('La contraseña debe tener al menos 6 caracteres.');
      return;
    }

    try {
      const newUser = registerUser({ fullName, email, password });
      const session = {
        id: newUser.id,
        name: newUser.fullName,
        email: newUser.email,
        role: newUser.role,
        loggedInAt: new Date().toISOString()
      };

      localStorage.setItem('session', JSON.stringify(session));
      sessionStorage.removeItem('session');

      alert(`Bienvenido, ${fullName}! Tu cuenta ha sido creada exitosamente.`);
      window.location.href = '/';
    } catch (error) {
      alert(error.message);
    }
  }, { capture: true });

  // Password strength indicator
  document.getElementById('regPassword')?.addEventListener('input', (e) => {
    const password = e.target.value;
    const bar = document.getElementById('strengthBar');
    const text = document.getElementById('strengthText');

    let strength = 0;
    if (password.length >= 6) strength += 25;
    if (password.length >= 10) strength += 25;
    if (/[A-Z]/.test(password)) strength += 25;
    if (/[0-9!@#$%^&*]/.test(password)) strength += 25;

    bar.style.width = strength + '%';

    if (strength <= 25) {
      bar.style.background = '#f44336';
      text.textContent = 'Débil';
      text.style.color = '#f44336';
    } else if (strength <= 50) {
      bar.style.background = '#ff9800';
      text.textContent = 'Regular';
      text.style.color = '#ff9800';
    } else if (strength <= 75) {
      bar.style.background = '#ffc107';
      text.textContent = 'Buena';
      text.style.color = '#ffc107';
    } else {
      bar.style.background = '#4caf50';
      text.textContent = 'Fuerte';
      text.style.color = '#4caf50';
    }
  });

  document.getElementById('registerForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);

    const fullName = formData.get('fullName');
    const email = formData.get('email');
    const password = formData.get('password');
    const confirmPassword = formData.get('confirmPassword');

    // Validation
    if (password !== confirmPassword) {
      alert('Las contraseñas no coinciden.');
      return;
    }

    if (password.length < 6) {
      alert('La contraseña debe tener al menos 6 caracteres.');
      return;
    }

    // Get existing users
    let users = JSON.parse(localStorage.getItem('users') || '[]');

    // Check if email already exists
    if (users.find(u => u.email === email)) {
      alert('Este correo ya está registrado. ¿Quieres iniciar sesión?');
      return;
    }

    // Create new user
    const newUser = {
      id: Date.now(),
      fullName,
      email,
      password,
      createdAt: new Date().toISOString()
    };

    users.push(newUser);
    localStorage.setItem('users', JSON.stringify(users));

    // Auto login
    const session = {
      id: newUser.id,
      name: newUser.fullName,
      email: newUser.email,
      loggedInAt: new Date().toISOString()
    };
    localStorage.setItem('session', JSON.stringify(session));

    alert(`¡Bienvenido, ${fullName}! Tu cuenta ha sido creada exitosamente.`);
    window.location.href = '/';
  });

  // Check if already logged in
  const session = getSession();
  if (session) {
    window.location.href = session.role === 'admin' ? '/admin' : '/';
  }
</script>
