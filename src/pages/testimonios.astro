---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SocialFloat from '../components/SocialFloat.astro';

const testimonials = [
  { id: 1, name: "María González", rating: 5, text: "¡El cheesecake de frutos rojos fue el éxito de mi fiesta! Todos quedaron encantados.", date: "2023-09-15" },
  { id: 2, name: "Carlos Mendoza", rating: 5, text: "Pedí cupcakes para el cumpleaños de mi hija y superaron todas las expectativas.", date: "2023-10-02" },
  { id: 3, name: "Ana Lucía Torres", rating: 5, text: "La consultoría para mi pastel de bodas fue increíble. Entendieron exactamente lo que quería.", date: "2023-10-20" }
];
---

<Layout title="Testimonios">
  <Header />
  
  <section style="background: linear-gradient(135deg, var(--secondary) 0%, var(--primary-light) 100%); padding: 40px 0;">
    <div class="container">
      <h1 class="section-title" style="margin-bottom: 0;">lo que dicen nuestros clientes</h1>
    </div>
  </section>

  <section style="padding: 60px 0;">
    <div class="container">
      <div id="testimonialsList" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; margin-bottom: 60px;">
        {testimonials.map(t => (
          <div style="background: white; border-radius: var(--radius); padding: 30px; box-shadow: var(--shadow);">
            <div style="display: flex; gap: 5px; margin-bottom: 15px;">
              {[...Array(5)].map((_, i) => (
                <svg width="20" height="20" viewBox="0 0 24 24" fill={i < t.rating ? "#ffc107" : "#e0e0e0"}>
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              ))}
            </div>
            <p style="color: var(--text); font-size: 0.95rem; line-height: 1.7; margin-bottom: 20px; font-style: italic;">"{t.text}"</p>
            <div style="display: flex; align-items: center; gap: 12px;">
              <div style="width: 45px; height: 45px; background: var(--primary-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary); font-weight: 600;">
                {t.name.charAt(0)}
              </div>
              <div>
                <div style="font-weight: 600; font-size: 0.9rem;">{t.name}</div>
                <div style="font-size: 0.8rem; color: var(--text-light);">{t.date}</div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Add Testimonial Form -->
      <div style="max-width: 600px; margin: 0 auto; background: white; border-radius: var(--radius); padding: 40px; box-shadow: var(--shadow);">
        <h3 style="font-size: 1.3rem; font-weight: 600; margin-bottom: 25px; text-align: center;">Comparte tu Experiencia</h3>
        <form id="testimonialForm">
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.9rem; font-weight: 500; margin-bottom: 8px;">Tu Nombre</label>
            <input type="text" name="name" required style="width: 100%; padding: 12px; border: 1.5px solid #e0e0e0; border-radius: var(--radius-sm); font-family: 'Poppins';" />
          </div>
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.9rem; font-weight: 500; margin-bottom: 8px;">Calificación</label>
            <div style="display: flex; gap: 10px;">
              {[1,2,3,4,5].map(star => (
                <label style="cursor: pointer;">
                  <input type="radio" name="rating" value={star} style="display: none;" />
                  <svg class="star-icon" width="30" height="30" viewBox="0 0 24 24" fill="#e0e0e0" data-value={star} style="transition: fill 0.2s;">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                </label>
              ))}
            </div>
          </div>
          <div style="margin-bottom: 20px;">
            <label style="display: block; font-size: 0.9rem; font-weight: 500; margin-bottom: 8px;">Tu Testimonio</label>
            <textarea name="text" rows="4" required style="width: 100%; padding: 12px; border: 1.5px solid #e0e0e0; border-radius: var(--radius-sm); font-family: 'Poppins'; resize: vertical;"></textarea>
          </div>
          <button type="submit" style="width: 100%; background: var(--primary); color: white; padding: 14px; border-radius: 30px; font-weight: 600; border: none; cursor: pointer; transition: all 0.3s;" onmouseover="this.style.background='var(--primary-dark)'" onmouseout="this.style.background='var(--primary)'">
            Enviar Testimonio
          </button>
        </form>
      </div>
    </div>
  </section>

  <SocialFloat />
  <Footer />

  <style>
    @media (max-width: 768px) {
      section:first-of-type {
        padding: 30px 0;
      }

      section:nth-of-type(2) {
        padding: 40px 0;
      }

      #testimonialsList {
        grid-template-columns: 1fr;
        gap: 20px;
        margin-bottom: 40px;
      }

      #testimonialsList > div {
        padding: 20px;
      }

      #testimonialsList p {
        font-size: 0.9rem;
      }

      #testimonialForm {
        max-width: 100%;
        padding: 30px 20px;
      }

      #testimonialForm h3 {
        font-size: 1.1rem;
      }
    }

    @media (max-width: 480px) {
      section:first-of-type {
        padding: 20px 0;
      }

      section:nth-of-type(2) {
        padding: 30px 0;
      }

      #testimonialsList {
        gap: 15px;
        margin-bottom: 30px;
      }

      #testimonialsList > div {
        padding: 15px;
      }

      #testimonialsList p {
        font-size: 0.85rem;
      }

      #testimonialForm {
        padding: 20px 15px;
      }

      #testimonialForm h3 {
        font-size: 1rem;
      }

      #testimonialForm input,
      #testimonialForm textarea {
        padding: 10px;
        font-size: 0.8rem;
      }

      #testimonialForm button {
        padding: 12px;
        font-size: 0.9rem;
      }
    }
  </style>
</Layout>

<script>
  import { addTestimonial, getTestimonials } from '../scripts/storage.js';
  
  // Star rating interaction
  document.querySelectorAll('.star-icon').forEach(star => {
    star.addEventListener('click', () => {
      const value = parseInt(star.dataset.value);
      document.querySelectorAll('.star-icon').forEach((s, i) => {
        s.style.fill = i < value ? '#ffc107' : '#e0e0e0';
      });
      document.querySelector(`input[name="rating"][value="${value}"]`).checked = true;
    });
  });
  
  document.getElementById('testimonialForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    
    addTestimonial({
      name: formData.get('name'),
      rating: parseInt(formData.get('rating') || '5'),
      text: formData.get('text')
    });
    
    alert('¡Gracias por tu testimonio!');
    e.target.reset();
    document.querySelectorAll('.star-icon').forEach(s => s.style.fill = '#e0e0e0');
    
    // Reload testimonials
    location.reload();
  });
</script>