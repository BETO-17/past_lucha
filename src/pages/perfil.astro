---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SocialFloat from '../components/SocialFloat.astro';
---

<Layout title="Mi Perfil">
  <Header />

  <main class="profile-page">
    <section class="container profile-card">
      <p class="eyebrow">Cuenta</p>
      <h1>Mi Perfil</h1>
      <p>
        Inicia sesion para ver y administrar los datos de tu cuenta.
      </p>
      <div class="actions">
        <a class="primary-link" href="/login">Iniciar sesion</a>
        <a class="secondary-link" href="/registro">Crear cuenta</a>
      </div>
    </section>
  </main>

  <SocialFloat />
  <Footer />
</Layout>

<style>
  .profile-page {
    min-height: 60vh;
    background: #fff7fa;
    padding: 96px 20px;
  }

  .profile-card {
    max-width: 720px;
    background: #ffffff;
    border: 1px solid #f3d4df;
    border-radius: 8px;
    padding: 48px;
    box-shadow: 0 8px 24px rgba(136, 14, 79, 0.08);
  }

  .eyebrow {
    color: var(--primary);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  h1 {
    color: var(--primary-dark);
    font-size: 2.4rem;
    margin-bottom: 12px;
  }

  .profile-card p:not(.eyebrow) {
    color: var(--text-light);
    font-size: 1rem;
    max-width: 520px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .primary-link,
  .secondary-link {
    border-radius: 8px;
    font-weight: 600;
    padding: 12px 20px;
  }

  .primary-link {
    background: var(--primary);
    color: #ffffff;
  }

  .secondary-link {
    border: 1px solid var(--primary);
    color: var(--primary);
  }
</style>
