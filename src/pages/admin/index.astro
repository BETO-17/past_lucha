---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Sidebar from '../../components/admin/Sidebar.jsx';
import Header from '../../components/admin/Header.jsx';
import StatsCards from '../../components/admin/StatsCards.jsx';
import ProductTable from '../../components/admin/ProductTable.jsx';

const user = {
  email: 'admin@donalucha.com',
  role: 'admin',
};
---

<AdminLayout title="Dashboard" user={user}>
  <script>
    import { getSession } from '../../scripts/storage.js';

    const session = getSession();

    if (session?.role !== 'admin') {
      window.location.href = '/login';
    }
  </script>

  <div class="flex min-h-screen overflow-hidden bg-[#fff7f8]">
    <Sidebar client:load />

    <main class="flex-1 overflow-y-auto bg-[linear-gradient(180deg,#fff7f8_0%,#fffafa_42%,#fff7f8_100%)] px-4 py-5 sm:px-6">
      <div class="mx-auto max-w-[1040px]">
        <header class="mb-5 rounded-[8px] border border-[#f4dce4] bg-white/80 px-5 py-4 shadow-[0_10px_30px_rgba(128,46,73,0.06)] backdrop-blur">
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <div>
              <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-[#ffe8f0] px-3 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-[#bd0b70]">
                <i class="fas fa-boxes-stacked text-[10px]"></i>
                Inventory
              </div>
              <h1 class="text-[22px] font-extrabold leading-tight text-[#4e3e44]">Inventory Management</h1>
              <p class="mt-2 max-w-[600px] text-[12px] leading-5 text-[#7b6870]">
                Manage your artisanal dessert catalog, track stock levels, and update pricing for spoonable delights.
              </p>
            </div>

            <div class="flex items-center gap-3">
              <Header client:load user={user} />
              <button class="hidden h-8 rounded-[5px] bg-[#bd0b70] px-3 text-[11px] font-bold text-white shadow-sm transition hover:bg-[#a60962] sm:inline-flex sm:items-center sm:gap-2">
                <i class="fas fa-plus text-[10px]"></i>
                New Product
              </button>
            </div>
          </div>
        </header>

        <StatsCards client:load />

        <ProductTable client:load />

        <section class="mt-5 grid gap-4 lg:grid-cols-[1fr_280px]">
          <div class="min-h-[126px] overflow-hidden rounded-[8px] border border-[#f0c9d3] bg-[#fde9ec] shadow-[0_8px_18px_rgba(128,46,73,0.05)]">
            <div class="flex h-full flex-col items-center justify-center px-6 py-6 text-center">
              <div class="mb-3 h-9 w-9 rounded-[6px] bg-white/70 text-[#bd0b70] flex items-center justify-center">
                <i class="fas fa-clipboard-list text-sm"></i>
              </div>
              <h2 class="text-[14px] font-extrabold text-[#6c5058]">Seasonal Menu Prep</h2>
              <p class="mt-2 text-[11px] text-[#8a747b]">Review stock for the upcoming Spring Collection.</p>
              <button class="mt-4 h-8 rounded-[5px] bg-[#6f4e57] px-4 text-[10px] font-bold text-white transition hover:bg-[#5d4149]">
                Review Drafts
              </button>
            </div>
          </div>

          <aside class="rounded-[8px] border border-[#f4dce4] bg-white px-4 py-4 shadow-[0_8px_18px_rgba(128,46,73,0.04)]">
            <p class="text-[11px] font-bold uppercase tracking-[0.12em] text-[#bd0b70]">Today</p>
            <div class="mt-4 space-y-3">
              <div class="flex items-center justify-between text-[12px]">
                <span class="text-[#7b6870]">Pending reviews</span>
                <strong class="text-[#4e3e44]">6</strong>
              </div>
              <div class="flex items-center justify-between text-[12px]">
                <span class="text-[#7b6870]">Restock alerts</span>
                <strong class="text-[#e34a56]">3</strong>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-[#fde9ec]">
                <div class="h-full w-[68%] rounded-full bg-[#bd0b70]"></div>
              </div>
            </div>
          </aside>
        </section>
      </div>
    </main>
  </div>
</AdminLayout>
