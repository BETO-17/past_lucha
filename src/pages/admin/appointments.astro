---
import AdminLayout from '../../layouts/AdminLayout.astro';
import Sidebar from '../../components/admin/Sidebar.jsx';
import Header from '../../components/admin/Header.jsx';

const user = {
  email: 'admin@donalucha.com',
  role: 'admin',
};

const calendarDays = Array.from({ length: 35 }, (_, index) => {
  const day = index - 1;
  const isToday = index === 5;
  const hasAppointment = [2, 3, 6, 10].includes(index);
  const appointmentTime = index === 2 ? '10:00' : index === 3 ? '14:30' : index === 6 ? '16:00' : '09:00';

  return {
    day: day > 0 ? day : '',
    isToday,
    hasAppointment,
    appointmentTime,
  };
});
---

<AdminLayout title="Appointments" user={user}>
  <script>
    import { getSession } from '../../scripts/storage.js';

    const session = getSession();

    if (session?.role !== 'admin') {
      window.location.href = '/login';
    }
  </script>

  <div class="flex min-h-screen overflow-hidden bg-[#fff7f8]">
    <Sidebar client:load />

    <main class="flex-1 overflow-y-auto bg-[linear-gradient(180deg,#fff7f8_0%,#fffafa_42%,#fff7f8_100%)] px-4 py-5 sm:px-6">
      <div class="mx-auto max-w-[1040px]">
        <header class="mb-5 rounded-[16px] border border-[#f4dce4] bg-white/90 px-6 py-6 shadow-[0_10px_30px_rgba(128,46,73,0.06)] backdrop-blur transition">
          <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
            <div>
              <div class="mb-3 inline-flex items-center gap-2 rounded-full bg-[#fde8f1] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-[#bd0b70]">
                <i class="fas fa-calendar-days text-[10px]"></i>
                Appointments
              </div>
              <h1 class="text-[28px] font-extrabold text-[#3d3037]">Manage pick-ups and tasting sessions</h1>
              <p class="mt-2 max-w-[680px] text-[12px] leading-6 text-[#7d666f]">
                Use this board to review upcoming orders, confirm customer details and keep service running smoothly.
              </p>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <button class="inline-flex h-9 items-center justify-center rounded-[8px] border border-[#f1d9e2] bg-white px-4 text-[12px] font-semibold text-[#805260] transition hover:border-[#bd0b70] hover:text-[#bd0b70]">
                <i class="fas fa-filter mr-2 text-[11px]"></i>
                Filter
              </button>
              <button class="inline-flex h-9 items-center justify-center rounded-[8px] bg-[#bd0b70] px-4 text-[12px] font-bold text-white shadow-[0_10px_20px_rgba(189,11,112,0.18)] transition hover:bg-[#a60962]">
                <i class="fas fa-calendar-day mr-2 text-[11px]"></i>
                Today
              </button>
              <Header client:load />
            </div>
          </div>
        </header>

        <section class="grid gap-5 lg:grid-cols-[1.65fr_1fr]">
          <div class="rounded-[24px] border border-[#f2d9e1] bg-white p-6 shadow-[0_14px_28px_rgba(128,46,73,0.07)]">
            <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-[12px] font-semibold uppercase tracking-[0.16em] text-[#bd0b70]">October 2024</p>
                <h2 class="mt-2 text-[20px] font-extrabold text-[#4d3d44]">Appointments Calendar</h2>
              </div>
              <div class="flex items-center gap-2 rounded-[14px] bg-[#fdf0f7] px-3 py-2 text-[12px] text-[#8d6d7a]">
                <button class="rounded-full border border-transparent bg-white px-3 py-2 text-[#7c5f6b] transition hover:border-[#efcede] hover:bg-[#fffaf9]">
                  <i class="fas fa-chevron-left"></i>
                </button>
                <button class="rounded-full border border-transparent bg-white px-3 py-2 text-[#7c5f6b] transition hover:border-[#efcede] hover:bg-[#fffaf9]">
                  <i class="fas fa-chevron-right"></i>
                </button>
              </div>
            </div>

            <div class="grid grid-cols-7 gap-2 text-center text-[11px] font-semibold uppercase tracking-[0.18em] text-[#a57b86]">
              <span>Sun</span>
              <span>Mon</span>
              <span>Tue</span>
              <span>Wed</span>
              <span>Thu</span>
              <span>Fri</span>
              <span>Sat</span>
            </div>

            <div class="mt-4 grid grid-cols-7 gap-3 text-[12px] text-[#6a545c]">
              {calendarDays.map((item) => (
                <div
                  class={`rounded-[18px] p-3 ${item.hasAppointment ? 'bg-[#fce7ef] border border-[#f5c9d8]' : 'bg-[#fff5f7] border border-[#f4e4ea]'} ${item.isToday ? 'ring-2 ring-[#bd0b70]/30' : ''}`}>
                  <div class="mb-2 text-[11px] font-bold text-[#4a3640]">{item.day}</div>
                  {item.hasAppointment ? (
                    <div class="rounded-[12px] bg-[#fde8f3] px-2 py-1 text-[10px] font-semibold text-[#bd0b70]">
                      {item.appointmentTime}
                    </div>
                  ) : (
                    <div class="h-6"></div>
                  )}
                </div>
              ))}
            </div>
          </div>

          <aside class="rounded-[24px] border border-[#f2d9e1] bg-white p-6 shadow-[0_14px_28px_rgba(128,46,73,0.07)]">
            <div class="mb-5 flex items-start justify-between gap-4">
              <div>
                <span class="inline-flex rounded-full bg-[#fde8f2] px-3 py-1 text-[11px] font-semibold text-[#bd0b70]">Pick-up</span>
                <h3 class="mt-4 text-[22px] font-extrabold text-[#3f2f35]">Order #492</h3>
                <p class="mt-2 text-[12px] text-[#7b6870]">Oct 3, 2024 · 14:30</p>
              </div>
              <button class="rounded-full border border-[#f4d9df] bg-[#fff5f8] px-3 py-2 text-[12px] font-semibold text-[#805060] transition hover:border-[#e3c3d1]">
                <i class="fas fa-ellipsis-v"></i>
              </button>
            </div>

            <div class="mb-6 rounded-[18px] bg-[#fff4f8] p-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[#bd0b70]">Customer details</p>
              <div class="mt-4 flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[#f6dce5] text-[13px] font-bold text-[#8b4d68]">MC</div>
                <div>
                  <p class="font-semibold text-[#3d2f34]">Maria Cortez</p>
                  <p class="text-[12px] text-[#7b6671]">+52 551234 5678</p>
                </div>
              </div>
            </div>

            <div class="space-y-3">
              <div class="rounded-[18px] border border-[#f3dee6] bg-[#fff6f9] p-4">
                <div class="flex items-center gap-3 text-[13px] font-semibold text-[#4b3541]">
                  <i class="fas fa-bowl-food text-sm text-[#bd0b70]"></i>
                  <span>Tiramisu Cucharable</span>
                </div>
                <p class="mt-2 text-[12px] text-[#7b6671]">Qty: 2</p>
              </div>
              <div class="rounded-[18px] border border-[#f3dee6] bg-[#fff6f9] p-4">
                <div class="flex items-center gap-3 text-[13px] font-semibold text-[#4b3541]">
                  <i class="fas fa-cup-straw text-sm text-[#bd0b70]"></i>
                  <span>Tres Leches Cup</span>
                </div>
                <p class="mt-2 text-[12px] text-[#7b6671]">Qty: 1</p>
              </div>
            </div>

            <div class="mt-6 rounded-[18px] border border-[#f4d8df] bg-[#fff4f8] p-4">
              <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-[#bd0b70]">Special notes</p>
              <p class="mt-3 text-[12px] leading-6 text-[#755f68]">“Please ensure the Tiramisu is extra chilled, it’s for a birthday party later in the evening.”</p>
            </div>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <button class="flex-1 rounded-[12px] border border-[#f3d4df] bg-white px-4 py-3 text-[12px] font-semibold text-[#6d525c] transition hover:border-[#d8b4c7]">
                Reschedule
              </button>
              <button class="flex-1 rounded-[12px] bg-[#bd0b70] px-4 py-3 text-[12px] font-bold text-white shadow-[0_10px_20px_rgba(189,11,112,0.2)] transition hover:bg-[#a60962]">
                Mark Complete
              </button>
            </div>
          </aside>
        </section>

        <div class="mt-5 rounded-[24px] border border-[#f2d9e1] bg-[#fff5f8] p-5 text-[#5e4852] shadow-[0_12px_24px_rgba(128,46,73,0.06)]">
          <p class="text-[12px] font-semibold uppercase tracking-[0.18em] text-[#bd0b70]">Upcoming Event</p>
          <p class="mt-3 text-[14px] font-semibold text-[#3e3037]">Weekend Dessert Tasting</p>
        </div>
      </div>
    </main>
  </div>
</AdminLayout>
